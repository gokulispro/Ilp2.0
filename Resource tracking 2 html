<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Resource Tracking</title>

<link rel="stylesheet"
href="resource-tracking.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

<!-- ================= HEADER ================= -->

<header>

<div class="logo">

<i class="fa-solid fa-heart-pulse"></i>

<div>

<h2>CuroNex</h2>

<p>Hospital Camp Management</p>

</div>

</div>

<div class="header-right">

<i class="fa-regular fa-bell"></i>

<div class="profile">

<img src="https://i.pravatar.cc/45">

<div>

<h4>Inventory Admin</h4>

<p>Administrator</p>

</div>

</div>

</div>

</header>

<!-- ================= CONTAINER ================= -->

<div class="container">

<!-- ================= SIDEBAR ================= -->

<aside>

<div class="menu">

<a href="inventory.html">

<i class="fa-solid fa-house"></i>

<span>Dashboard</span>

</a>

<a href="add-resource.html">

<i class="fa-solid fa-circle-plus"></i>

<span>Add Resource</span>

</a>

<a href="transfer-request.html">

<i class="fa-solid fa-arrow-right-arrow-left"></i>

<span>Transfer Request</span>

</a>

<a class="active">

<i class="fa-solid fa-truck-fast"></i>

<span>Resource Tracking</span>

</a>

</div>

</aside>

<!-- ================= MAIN ================= -->

<main>

<div class="page-header">

<h1>

Resource Tracking

</h1>

<p>

Track every resource transfer between hospitals and camps.

</p>

</div>

<!-- ================= TRACKING CARDS ================= -->

<div class="cards">

<div class="track-card">

<h2>

24

</h2>

<p>

Transfers Today

</p>

<i class="fa-solid fa-truck-fast"></i>

</div>

<div class="track-card">

<h2>

12

</h2>

<p>

In Transit

</p>

<i class="fa-solid fa-route"></i>

</div>

<div class="track-card">

<h2>

176

</h2>

<p>

Delivered

</p>

<i class="fa-solid fa-circle-check"></i>

</div>

<div class="track-card">

<h2>

5

</h2>

<p>

Delayed

</p>

<i class="fa-solid fa-clock"></i>

</div>

</div>

<!-- ================= TRACKING TABLE ================= -->

<div class="tracking-card">

<div class="card-header">

<h2>

Transfer Tracking

</h2>

<div class="search">

<i class="fa-solid fa-magnifying-glass"></i>

<input

type="text"

id="searchTransfer"

placeholder="Search Transfer">

</div>

</div>


<!-- ================= TRACKING TABLE ================= -->

<table id="trackingTable">

<thead>

<tr>

<th>Transfer ID</th>

<th>Resource</th>

<th>Source</th>

<th>Destination</th>

<th>Quantity</th>

<th>Status</th>

<th>Dispatch</th>

<th>Expected Delivery</th>

<th>Action</th>

</tr>

</thead>

<tbody>

<tr>

<td>TR001</td>

<td>Paracetamol</td>

<td>Government Hospital</td>

<td>Camp A</td>

<td>200</td>

<td>

<span class="status transit">

In Transit

</span>

</td>

<td>02/07/2026</td>

<td>03/07/2026</td>

<td>

<button class="view-btn">

<i class="fa-solid fa-eye"></i>

View

</button>

</td>

</tr>

<tr>

<td>TR002</td>

<td>Blood Bags</td>

<td>Blood Bank</td>

<td>Hospital B</td>

<td>40</td>

<td>

<span class="status delivered">

Delivered

</span>

</td>

<td>01/07/2026</td>

<td>02/07/2026</td>

<td>

<button class="view-btn">

<i class="fa-solid fa-eye"></i>

View

</button>

</td>

</tr>

<tr>

<td>TR003</td>

<td>Surgical Gloves</td>

<td>Warehouse</td>

<td>Camp C</td>

<td>500</td>

<td>

<span class="status delayed">

Delayed

</span>

</td>

<td>30/06/2026</td>

<td>01/07/2026</td>

<td>

<button class="view-btn">

<i class="fa-solid fa-eye"></i>

View

</button>

</td>

</tr>

</tbody>

</table>

</div>

<!-- ================= PROGRESS CARD ================= -->

<div class="progress-card">

<h2>

Transfer Progress

</h2>

<div class="timeline">

<div class="timeline-item completed">

<div class="circle">

<i class="fa-solid fa-check"></i>

</div>

<div>

<h4>Request Submitted</h4>

<p>02 Jul 2026 - 09:15 AM</p>

</div>

</div>

<div class="timeline-item completed">

<div class="circle">

<i class="fa-solid fa-check"></i>

</div>

<div>

<h4>Approved</h4>

<p>02 Jul 2026 - 10:30 AM</p>

</div>

</div>

<div class="timeline-item active">

<div class="circle">

<i class="fa-solid fa-truck-fast"></i>

</div>

<div>

<h4>In Transit</h4>

<p>Vehicle departed warehouse</p>

</div>

</div>

<div class="timeline-item">

<div class="circle">

<i class="fa-solid fa-location-dot"></i>

</div>

<div>

<h4>Delivered</h4>

<p>Awaiting delivery</p>

</div>

</div>

</div>

</div>

</main>

</div>

<script src="resource-tracking.js"></script>

</body>

</html>


