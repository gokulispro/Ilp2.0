<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Inventory Dashboard</title>

<link rel="stylesheet"
href="inventory.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

<!-- ================= HEADER ================= -->

<header>

<div class="logo">

<i class="fa-solid fa-heart-pulse"></i>

<div>

<h2>CuroNex</h2>

<p>Hospital Camp Management</p>

</div>

</div>

<div class="header-right">

<i class="fa-regular fa-bell"></i>

<div class="profile">

<img src="https://i.pravatar.cc/45">

<div>

<h4>Inventory Admin</h4>

<p>Administrator</p>

</div>

</div>

</div>

</header>

<!-- ================= LAYOUT ================= -->

<div class="container">

<!-- ================= SIDEBAR ================= -->

<aside>

<div class="menu">

<a class="active">

<i class="fa-solid fa-house"></i>

<span>Dashboard</span>

</a>

<a>

<i class="fa-solid fa-boxes-stacked"></i>

<span>Inventory</span>

</a>

<a>

<i class="fa-solid fa-circle-plus"></i>

<span>Add Resource</span>

</a>

<a>

<i class="fa-solid fa-arrow-right-arrow-left"></i>

<span>Transfer Request</span>

</a>

<a>

<i class="fa-solid fa-truck-fast"></i>

<span>Resource Tracking</span>

</a>

<a>

<i class="fa-solid fa-chart-line"></i>

<span>Reports</span>

</a>

</div>

<div class="support">

<i class="fa-solid fa-headset"></i>

<h3>Support</h3>

<p>Need help?</p>

</div>

</aside>

<!-- ================= MAIN ================= -->

<main>

<div class="top-section">

<div>

<h1>Inventory Dashboard</h1>

<p>

Monitor all hospital resources in one place.

</p>

</div>

<button>

<i class="fa-solid fa-plus"></i>

Add Resource

</button>

</div>

<!-- ================= SUMMARY CARDS ================= -->

<div class="cards">

<div class="dashboard-card">

<div>

<h2>325</h2>

<p>Total Resources</p>

</div>

<i class="fa-solid fa-boxes-stacked"></i>

</div>

<div class="dashboard-card">

<div>

<h2>18</h2>

<p>Low Stock</p>

</div>

<i class="fa-solid fa-triangle-exclamation"></i>

</div>

<div class="dashboard-card">

<div>

<h2>42</h2>

<p>Transfer Requests</p>

</div>

<i class="fa-solid fa-arrow-right-arrow-left"></i>

</div>

<div class="dashboard-card">

<div>

<h2>14</h2>

<p>Active Camps</p>

</div>

<i class="fa-solid fa-hospital"></i>

</div>

</div>

<!-- ================= INVENTORY CARD ================= -->

<div class="inventory-card">

<div class="card-header">

<h2>Inventory Resources</h2>

<div class="search">

<i class="fa-solid fa-magnifying-glass"></i>

<input
type="text"
placeholder="Search Resource">

</div>

</div>

<!-- ================= FILTER BUTTONS ================= -->

<div class="filters">

<button class="active-filter">

Medicines

</button>

<button>

Equipment

</button>

<button>

Blood Units

</button>

<button>

Consumables

</button>

</div>

<!-- ================= TABLE ================= -->

<table>

<thead>

<tr>

<th>ID</th>

<th>Resource</th>

<th>Category</th>

<th>Available</th>

<th>Location</th>

<th>Status</th>

<th>Actions</th>

</tr>

</thead>

<tbody>

<tr>

<td>MED001</td>

<td>Paracetamol</td>

<td>Medicine</td>

<td>320</td>

<td>Hospital A</td>

<td>

<span class="status available">

Available

</span>

</td>

<td>

<i class="fa-solid fa-pen-to-square edit"></i>

<i class="fa-solid fa-trash delete"></i>

</td>

</tr>

<tr>

<td>EQ014</td>

<td>Wheelchair</td>

<td>Equipment</td>

<td>12</td>

<td>Camp 3</td>

<td>

<span class="status low">

Low Stock

</span>

</td>

<td>

<i class="fa-solid fa-pen-to-square edit"></i>

<i class="fa-solid fa-trash delete"></i>

</td>

</tr>

<tr>

<td>BL008</td>

<td>Blood Bags</td>

<td>Blood Unit</td>

<td>56</td>

<td>Blood Bank</td>

<td>

<span class="status available">

Available

</span>

</td>

<td>

<i class="fa-solid fa-pen-to-square edit"></i>

<i class="fa-solid fa-trash delete"></i>

</td>

</tr>

<tr>

<td>CO021</td>

<td>Surgical Gloves</td>

<td>Consumables</td>

<td>8</td>

<td>Camp 5</td>

<td>

<span class="status danger">

Critical

</span>

</td>

<td>

<i class="fa-solid fa-pen-to-square edit"></i>

<i class="fa-solid fa-trash delete"></i>

</td>

</tr>

<tr>

<td>MD034</td>

<td>Insulin</td>

<td>Medicine</td>

<td>76</td>

<td>Hospital B</td>

<td>

<span class="status available">

Available

</span>

</td>

<td>

<i class="fa-solid fa-pen-to-square edit"></i>

<i class="fa-solid fa-trash delete"></i>

</td>

</tr>

</tbody>

</table>

<!-- ================= PAGINATION ================= -->

<div class="pagination">

<button>

Previous

</button>

<button class="page active-page">

1

</button>

<button class="page">

2

</button>

<button class="page">

3

</button>

<button>

Next

</button>

</div>

</div>

<!-- ================= RIGHT PANEL ================= -->

<div class="right-panel">

<div class="analytics">

<h3>

Inventory Overview

</h3>

<div class="progress-card">

<p>Medicines</p>

<div class="progress">

<div style="width:88%"></div>

</div>

</div>

<div class="progress-card">

<p>Equipment</p>

<div class="progress">

<div style="width:72%"></div>

</div>

</div>

<div class="progress-card">

<p>Blood Units</p>

<div class="progress">

<div style="width:63%"></div>

</div>

</div>

<div class="progress-card">

<p>Consumables</p>

<div class="progress">

<div style="width:91%"></div>

</div>

</div>

</div>

<div class="activity">

<h3>

Recent Activity

</h3>

<ul>

<li>

✔ 120 Syringes Added

</li>

<li>

✔ Blood Units Updated

</li>

<li>

✔ Wheelchairs Transferred

</li>

<li>

✔ Camp Inventory Synced

</li>

</ul>

</div>

</div>

</main>

</div>

</body>

</html>

