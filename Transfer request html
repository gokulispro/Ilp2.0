<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Transfer Request</title>

<link rel="stylesheet"
href="transfer-request.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

<!-- ================= HEADER ================= -->

<header>

<div class="logo">

<i class="fa-solid fa-heart-pulse"></i>

<div>

<h2>CuroNex</h2>

<p>Hospital Camp Management</p>

</div>

</div>

<div class="header-right">

<i class="fa-regular fa-bell"></i>

<div class="profile">

<img src="https://i.pravatar.cc/45">

<div>

<h4>Inventory Admin</h4>

<p>Administrator</p>

</div>

</div>

</div>

</header>

<!-- ================= CONTAINER ================= -->

<div class="container">

<!-- ================= SIDEBAR ================= -->

<aside>

<div class="menu">

<a href="inventory.html">

<i class="fa-solid fa-house"></i>

<span>Dashboard</span>

</a>

<a href="add-resource.html">

<i class="fa-solid fa-circle-plus"></i>

<span>Add Resource</span>

</a>

<a class="active">

<i class="fa-solid fa-arrow-right-arrow-left"></i>

<span>Transfer Request</span>

</a>

<a href="resource-tracking.html">

<i class="fa-solid fa-truck-fast"></i>

<span>Resource Tracking</span>

</a>

</div>

</aside>

<!-- ================= MAIN ================= -->

<main>

<div class="page-header">

<h1>Create Transfer Request</h1>

<p>

Transfer medical resources between hospitals and medical camps.

</p>

</div>

<div class="transfer-card">

<form id="transferForm">

<div class="form-grid">

<!-- ================= Request ID ================= -->

<div class="input-group">

<label for="requestId">

Request ID

</label>

<input
type="text"
id="requestId"
name="requestId"
value="TR0001"
readonly>

</div>

<!-- ================= Request Date ================= -->

<div class="input-group">

<label for="requestDate">

Request Date

</label>

<input
type="date"
id="requestDate"
name="requestDate">

</div>

<!-- ================= Source Hospital ================= -->

<div class="input-group">

<label for="sourceHospital">

Source Hospital / Camp

</label>

<select
id="sourceHospital"
name="sourceHospital">

<option value="">Select Source</option>

<option>Government Hospital</option>

<option>Private Hospital</option>

<option>Medical Camp A</option>

<option>Medical Camp B</option>

</select>

</div>

<!-- ================= Destination Hospital ================= -->

<div class="input-group">

<label for="destinationHospital">

Destination Hospital / Camp

</label>

<select
id="destinationHospital"
name="destinationHospital">

<option value="">Select Destination</option>

<option>Government Hospital</option>

<option>Private Hospital</option>

<option>Medical Camp A</option>

<option>Medical Camp B</option>

</select>

</div>

<!-- ================= Resource ================= -->

<div class="input-group">

<label for="resourceName">

Resource Name

</label>

<select
id="resourceName"
name="resourceName">

<option value="">Select Resource</option>

<option>Paracetamol</option>

<option>Wheelchair</option>

<option>Blood Bag</option>

<option>Surgical Gloves</option>

<option>Syringe</option>

</select>

</div>

<!-- ================= Available Quantity ================= -->

<div class="input-group">

<label for="availableQuantity">

Available Quantity

</label>

<input
type="number"
id="availableQuantity"
name="availableQuantity"
placeholder="Auto-filled later"
readonly>

</div>

<!-- ================= Requested Quantity ================= -->

<div class="input-group">

<label for="requestedQuantity">

Requested Quantity

</label>

<input
type="number"
id="requestedQuantity"
name="requestedQuantity"
placeholder="Enter Quantity">

</div>

<!-- ================= Priority ================= -->

<div class="input-group">

<label for="priority">

Priority

</label>

<select
id="priority"
name="priority">

<option value="">Select Priority</option>

<option>Normal</option>

<option>High</option>

<option>Emergency</option>

</select>

</div>

<!-- ================= Expected Delivery ================= -->

<div class="input-group">

<label for="deliveryDate">

Expected Delivery Date

</label>

<input
type="date"
id="deliveryDate"
name="deliveryDate">

</div>

<!-- ================= Transport Mode ================= -->

<div class="input-group">

<label for="transportMode">

Transport Mode

</label>

<select
id="transportMode"
name="transportMode">

<option value="">Select Mode</option>

<option>Hospital Vehicle</option>

<option>Ambulance</option>

<option>Courier</option>

<option>Medical Logistics</option>

</select>

</div>

<!-- ================= Reason ================= -->

<div class="input-group full">

<label for="transferReason">

Reason for Transfer

</label>

<textarea
id="transferReason"
name="transferReason"
rows="5"
placeholder="Explain why this transfer is required..."></textarea>

</div>

<!-- ================= Attachment ================= -->

<div class="input-group full">

<label for="attachment">

Supporting Document (Optional)

</label>

<input
type="file"
id="attachment"
name="attachment"
accept=".pdf,.jpg,.jpeg,.png">

</div>

</div>

<!-- ================= SUMMARY ================= -->

<div class="summary-card">

<h3>

<i class="fa-solid fa-file-circle-check"></i>

Transfer Summary

</h3>

<div class="summary-grid">

<div>

<span>Resource</span>

<p id="summaryResource">

Not Selected

</p>

</div>

<div>

<span>Source</span>

<p id="summarySource">

Not Selected

</p>

</div>

<div>

<span>Destination</span>

<p id="summaryDestination">

Not Selected

</p>

</div>

<div>

<span>Priority</span>

<p id="summaryPriority">

Normal

</p>

</div>

<div>

<span>Status</span>

<p id="summaryStatus">

Pending Approval

</p>

</div>

<div>

<span>Transfer Date</span>

<p id="summaryDate">

--/--/----</p>

</div>

</div>

</div>

<!-- ================= BUTTONS ================= -->

<div class="button-area">

<button
type="reset"
class="secondary"
id="resetTransferBtn">

<i class="fa-solid fa-rotate-left"></i>

Reset

</button>

<button
type="submit"
class="primary"
id="submitTransferBtn">

<i class="fa-solid fa-paper-plane"></i>

Submit Request

</button>

</div>

</form>

</div>

</main>

</div>

<!-- ================= JAVASCRIPT ================= -->

<script src="transfer-request.js"></script>

</body>

</html>
